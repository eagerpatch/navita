{
  "name": "@navita/engine",
  "version": "0.1.3",
  "description": "Navitas CSS-in-JS engine",
  "keywords": [
    "css-in-js",
    "engine",
    "navita"
  ],
  "private": false,
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./src/index.ts"
    }
  },
  "publishConfig": {
    "directory": "dist",
    "linkDirectory": false
  },
  "scripts": {
    "build": "build",
    "dev": "build --dev",
    "test": "jest"
  },
  "dependencies": {
    "sort-css-media-queries": "^2.2.0",
    "@emotion/hash": "^0.9.1",
    "source-map": "^0.7.4",
    "cacache": "^18.0.2",
    "cache-manager": "^5.5.1"
  },
  "devDependencies": {
    "@navita/types": "workspace:*",
    "@types/cacache": "^17.0.2"
  },
  "license": "MIT",
  "author": "Eagerpatch",
  "repository": {
    "type": "git",
    "url": "https://github.com/eagerpatch/navita.git",
    "directory": "packages/engine"
  }
}
